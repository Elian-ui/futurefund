PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/futurefund
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
FRONTEND_URL=http://localhost:3000
MAIL_ENABLED=true
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
MAIL_FROM=FutureFund <noreply@yourdomain.com>
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=20
AUTH_MAX_LOGIN_ATTEMPTS=5
AUTH_LOCKOUT_MS=900000
PASSWORD_RESET_TOKEN_TTL_MS=1800000
EMAIL_VERIFICATION_TOKEN_TTL_MS=86400000

# Comma-separated browser origins allowed to call the backend.
# Add your LAN frontend URL when testing from a phone.
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:5173,http://192.168.70.113:3000

# Background jobs. Set an interval to 0 to disable only that job.
JOBS_ENABLED=true
PAYOUT_JOB_INTERVAL_MS=60000
PAYOUT_JOB_LOCK_MS=300000
SUPPORT_JOB_INTERVAL_MS=300000
SUPPORT_JOB_LOCK_MS=600000
SUPPORT_STALE_AFTER_MS=86400000
